---
import ProjectCard from "./ProjectCard.tsx";
import SectionReveal from "./SectionReveal.tsx";
import { projects } from "../data/projects";

const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<section id="projects" class="py-20 bg-surface-overlay">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <SectionReveal client:visible>
      <h2 class="text-2xl sm:text-3xl font-serif text-text-primary mb-2">
        Projects
      </h2>
      <p class="text-text-secondary mb-10">
        Interactive prototypes that demonstrate instructional design in action.
      </p>
    </SectionReveal>
    {featured.length > 0 && (
      <div class="grid gap-6 mb-6">
        {featured.map((project, i) => (
          <ProjectCard client:visible project={project} index={i} featured />
        ))}
      </div>
    )}
    <div class="grid gap-6 sm:grid-cols-3">
      {rest.map((project, i) => (
        <ProjectCard client:visible project={project} index={i + featured.length} />
      ))}
    </div>
  </div>
</section>
