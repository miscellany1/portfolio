---
import HeroReveal from "./HeroReveal.tsx";
---

<section class="py-32 sm:py-40 lg:py-48">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <HeroReveal client:load>
      <p class="text-accent font-medium text-sm tracking-wide uppercase mb-4">
        Senior Instructional Designer
      </p>
      <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl text-text-primary mb-6">
        Where game design meets learning design.
      </h1>
      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-10">
        I design scenario-based training and custom web experiences using
        Articulate Storyline, Rise, and React.
      </p>
      <div class="flex items-center justify-center">
        <a
          href="#projects"
          class="inline-flex items-center gap-2 px-6 py-3 bg-accent hover:bg-accent-hover text-white font-medium rounded-lg transition-colors"
        >
          See My Work
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
      </div>
    </HeroReveal>
  </div>
</section>
